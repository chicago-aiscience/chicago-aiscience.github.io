---
interface ReferenceItem {
    text: string
    href?: string | undefined
}

interface Props {
    imageUrl?: string | undefined
    imageAlt?: string | undefined
    imageFallback?: string | undefined
    referentia?: ReferenceItem[] | undefined
}

const { imageUrl, imageAlt, imageFallback, referentia } = Astro.props
---

<style>
    .card {
        width: 200px;
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius);
        overflow: hidden;
        background: var(--color-primary);
        box-shadow: var(--color-secondary) 4px 4px;
        transition: transform var(--transition-speed) ease;
    }

    .card-media {
        height: 200px;
        background: var(--color-secondary);
    }
    .card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-header {
        padding: 0.5rem;
        background: var(--color-accent)
    }

    .card-referentia {
        padding: 0.5rem;
        font-size: 0.9rem;
        color: var(--color-text-muted);
    }
    .reference-item {
        margin-top: 0.25rem;
    }
    .reference-link {
        color: inherit;
        text-decoration: none;
    }
    .reference-link:hover {
        /* color: var(--color-secondary); */
        background: var(--color-accent);
    }

    .card-content {
        padding: 0.5rem;
        opacity: 0;
        height: 0;
        overflow: hidden;
    }
</style>

<!-- TODO: image fallback is not verified -->
<div class="card">
    {imageUrl && <div class="card-media">
        <img
            src={imageUrl}
            alt={imageAlt ?? ''}
            onerror="this.onerror=null; this.src=this.getAttribute('data-fallback')"
            data-fallback={imageFallback}
        />
    </div>}
    <div class="card-header"><slot name="header" /></div>
    <div class="card-referentia">
        {referentia?.map(ref => (
            <div class="reference-item">
                {ref.href
                    ? <a class="reference-link" href={ref.href} target="_blank">{ref.text}</a>
                    : <span>{ref.text}</span>
                }
            </div>
        ))}
    </div>
    <div class="card-content"><slot name="content" /></div>
</div>

---
import { siteConfig, pages } from '../config'

interface Props {
    nav?: typeof siteConfig.navItems
}

const { nav = siteConfig.navItems } = Astro.props
const { pathname } = Astro.url
---

<aside>
    <nav>
        <div class="brand">
            <a href="/">{siteConfig.brand}</a>
        </div>

        <ul>
            {nav.map(key => (
                <li><a class={pathname === pages[key].path ? 'active' : ''} href={pages[key].path}>{pages[key].title}</a></li>
            ))}
        </ul>
    </nav>
</aside>

<style>
    aside {
        width: 220px;
        min-height: 100vh;
        background: var(--color-secondary);
        border-right: 1px solid var(--color-border);
    }

    nav {
        position: sticky;
        top: 0;
        padding: 2rem;
    }

    .brand {
        margin-bottom: 2rem;
        font-weight: 600;
        font-size: 1.4rem;
        letter-spacing: -0.025em;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    li { margin: 0.75rem 0; }

    a {
        text-decoration: none;
        color: var(--color-text-muted);
        transition: all var(--transition-speed) ease;
        display: block;
        padding: 0.25rem 0.5rem;
        border-radius: var(--border-radius);
    }

    a.active {
        color: var(--color-text);
        background: var(--color-accent);
        font-weight: 500;
    }

    a:hover {
        color: var(--color-text);
        background: var(--color-primary);
    }

    .brand a { color: var(--color-text); }
</style>
---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from './BaseLayout.astro'

interface Props {
    fellow: CollectionEntry<'fellows'>
}

const { fellow } = Astro.props
const {
    data: { name, metaImageUrl, idCohort: cohort, idGithub }
} = fellow;
const referentia = [
    { text: `Cohort ${cohort}` },
    { text: `GitHub: ${idGithub?.[0]}`, href: `https://github.com/${idGithub?.[0]}` }
]
---

<BaseLayout
    title={name}
    description={`Profile of ${name}, cohort ${cohort}`}
>
    <article class="profile">
        <header class="profile-header">
            <h1>{name}</h1>
            <div class="profile-referentia">
                {referentia.map(ref => (
                    <span>{ref.href ? <a href={ref.href}>{ref.text}</a> : ref.text}</span>
                ))}
            </div>
            {metaImageUrl?.[0] && (<img src={metaImageUrl[0]} alt={name} />)}
        </header>
        <div class="profile-content">
            <slot />
        </div>
    </article>
</BaseLayout>

<style>
.profile {
    max-width: var(--max-width);
    margin: 0 auto;
}

.profile-header {
    display: grid;
    grid-template-columns: 3fr 2fr;
    align-items: center;
}

.profile-header img {
    width: 100%;
    border-radius: var(--border-radius);
    box-shadow: var(--color-secondary) 4px 4px;
    grid-column: 2;
    grid-row: 1/3;
}

.profile-referentia {
    display: flex;
    grid-column: 1 / -1;
}
</style>

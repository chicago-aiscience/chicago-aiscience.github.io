---
import FooterV0 from '../components/Footer-v0.astro';
import SidebarV0 from '../components/Sidebar-v0.astro';
import '../styles/global.css'

interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description} />
    <title>{title}</title>
</head>
<body>

    <div class="layout">

            <aside class=`layout__sidebar`>
                <slot name="sidebar-aside">
                    <SidebarV0 />
                </slot>
            </aside>

            <div class="layout__main">
                <header class="layout__header">
                    <h3>{title}</h3>
                </header>


                <main class="layout__content">
                    <div class="layout__article">
                        <slot />
                    </div>


                    <aside class={`layout__aside ${Astro.slots.has('aside') ? '' : 'layout__aside--hidden'}`}>
                        <slot name="aside"></slot>
                    </aside>
                </main>

                <footer class="layout__footer">
                    <slot name="footer">
                        <FooterV0 />
                    </slot>
                </footer>
            </div>

    </div>


</body>
</html>

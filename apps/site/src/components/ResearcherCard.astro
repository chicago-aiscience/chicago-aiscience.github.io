---
import type { CollectionEntry } from "astro:content"
import BasicCard from "../layouts/BasicCard.astro"
// import type { FellowEntry } from "src/env"

interface Props {
    fellow: CollectionEntry<'fellows'>
}
const { fellow } = Astro.props
const { metaName, cohort, idGithub, metaImageUrl } = fellow.data
---

<BasicCard
    imageUrl={metaImageUrl?.[0]}
    data-fallback={metaImageUrl?.[1]}
    referentia={[
        { text: `Cohort ${cohort}`},
        ...idGithub?.map((user: string) => ({
            text: `GitHub: ${user}`,
            href: `https://github.com/${user}`
        }
        )) ?? []
    ]}
>
    <h3 slot="header">
        <a href={`/fellows/${fellow.slug}`}>{metaName}</a>
    </h3>
</BasicCard>
